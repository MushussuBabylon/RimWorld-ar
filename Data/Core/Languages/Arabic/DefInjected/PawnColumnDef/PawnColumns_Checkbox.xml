<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN: Follow master while the master is drafted. -->
  <FollowDrafted.headerTip>يتبع السيد أثناء تجنيده.</FollowDrafted.headerTip>
  
  <!-- EN: Follow master while the master is doing field work (hunting or taming animals). -->
  <FollowFieldwork.headerTip>يتبع السيد أثناء العمل الميداني (الصيد أو ترويض الحيوانات).</FollowFieldwork.headerTip>
  
  <!-- EN: Mark animals to be hunted by your hunters.\n\nOnly hunters with suitable ranged weapons will hunt. -->
  <Hunt.headerTip>علّم الحيوانات ليصطادها الصيادون.\n\nفقط الصيادون الذين لديهم أسلحة بعيدة مناسبة سيصطادون.</Hunt.headerTip>
  
  <!-- EN: Release to wild -->
  <ReleaseAnimalToWild.headerTip>أطلق إلى البرية</ReleaseAnimalToWild.headerTip>
  
  <!-- EN: Slaughter -->
  <Slaughter.headerTip>ذبح</Slaughter.headerTip>
  
  <!-- EN: Sterilize -->
  <Sterile.headerTip>تعقيم</Sterile.headerTip>
  
  <!-- EN: Tame a wild animal. -->
  <Tame.headerTip>روّض حيواناً برياً.</Tame.headerTip>
  
</LanguageData>