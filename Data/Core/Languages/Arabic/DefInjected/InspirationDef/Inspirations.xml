  <!-- EN: go frenzy -->
  <Frenzy_Go.label>هياج الحركة</Frenzy_Go.label>
  <!-- EN: Inspired: Go frenzy -->
  <Frenzy_Go.baseInspectLine>ملهم: هياج الحركة</Frenzy_Go.baseInspectLine>
  <!-- EN: [PAWN_pronoun] will move faster for the next 8 days. -->
  <Frenzy_Go.beginLetter>سيتحرك [PAWN_pronoun] بشكل أسرع خلال الأيام الثمانية القادمة.</Frenzy_Go.beginLetter>
  <Frenzy_Go.beginLetterLabel>إلهام (هياج الحركة)</Frenzy_Go.beginLetterLabel>
  <!-- EN: {0} is no longer inspired (go frenzy). -->
  <Frenzy_Go.endMessage>لم يعد {0} ملهمًا (هياج الحركة).</Frenzy_Go.endMessage>
  
