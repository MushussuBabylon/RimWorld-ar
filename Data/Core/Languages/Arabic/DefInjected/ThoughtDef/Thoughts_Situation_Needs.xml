  <!-- EN: chemical satisfaction -->
  <DrugDesireFascinationSatisfied.stages.chemical_satisfaction.label>شبع كيميائي</DrugDesireFascinationSatisfied.stages.chemical_satisfaction.label>
  <!-- EN: I'm fascinated by drugs, and I am fully satisfied with my drug consumption. -->
  <DrugDesireFascinationSatisfied.stages.chemical_satisfaction.description>أنا مفتون بالمخدرات، وأنا راضٍ تمامًا عن استهلاكي للمخدرات.</DrugDesireFascinationSatisfied.stages.chemical_satisfaction.description>
  
