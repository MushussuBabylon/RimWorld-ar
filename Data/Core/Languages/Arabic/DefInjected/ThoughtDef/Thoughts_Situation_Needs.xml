  <!-- EN: chemical hunger -->
  <DrugDesireFascination.stages.chemical_hunger.label>جوع كيميائي</DrugDesireFascination.stages.chemical_hunger.label>
  <!-- EN: I'm fascinated by drugs. I want to experience them a lot harder. -->
  <DrugDesireFascination.stages.chemical_hunger.description>أنا مفتون بالمخدرات. أريد تجربتها بشكل أقوى بكثير.</DrugDesireFascination.stages.chemical_hunger.description>
  <!-- EN: chemical starvation -->
  <DrugDesireFascination.stages.chemical_starvation.label>تجويع كيميائي</DrugDesireFascination.stages.chemical_starvation.label>
