  <!-- Thought_Situational, ThoughtWorker_ColonistLeftUnburied. Label: {PAWN}. Description: {PAWN} -->
  <!-- EN: colonist left unburied -->
  <ColonistLeftUnburied.stages.colonist_left_unburied.label>مستعمر ترك دون دفن</ColonistLeftUnburied.stages.colonist_left_unburied.label>
  <!-- EN: One of us died and we're just leaving them lying in the open. Nobody should be left like that. People deserve a decent burial. -->
  <ColonistLeftUnburied.stages.colonist_left_unburied.description>مات أحدنا ونحن فقط نتركه ملقى في العراء. لا ينبغي ترك أحد هكذا. الناس يستحقون دفناً لائقاً.</ColonistLeftUnburied.stages.colonist_left_unburied.description>
  
