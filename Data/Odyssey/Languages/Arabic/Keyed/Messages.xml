<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>

  <!-- Grav engine/substructrues -->
  <!-- EN: Must be placed on gravship substructure. -->
  <MessageMustBePlacedOnSubstructure>يجب وضعه على البنية التحتية لسفينة الجاذبية.</MessageMustBePlacedOnSubstructure>
  <!-- EN: Must be placed within the radius of a grav engine or grav field extender. -->
  <MessageMustBePlacedInRangeOfGravEngineOrExtender>يجب وضعه ضمن نطاق محرك جاذبية أو موسع مجال جاذبية.</MessageMustBePlacedInRangeOfGravEngineOrExtender>
  <!-- EN: Cannot be placed under rock or mountain roofs. -->
  <MessageCannotPlaceUnderRockRoof>لا يمكن وضعه تحت أسقف صخرية أو جبلية.</MessageCannotPlaceUnderRockRoof>
  <!-- EN: {ACTIVATOR_labelShort} has finished hacking {SUBJECT_definite}. -->
  <MessageStabilizerDeactivated>أنهى {ACTIVATOR_labelShort} اختراق {SUBJECT_definite}.</MessageStabilizerDeactivated>
  <!-- EN: Can't be placed on gravship substructure. -->
  <MessageCannotPlaceOverSubstructure>لا يمكن وضعه على البنية التحتية لسفينة الجاذبية.</MessageCannotPlaceOverSubstructure>
  <!-- EN: Gravship substructure is blocked. -->
  <MessageSubstructureBlocked>البنية التحتية لسفينة الجاذبية مسدودة.</MessageSubstructureBlocked>
  <!-- EN: Must be placed within range of a grav engine. -->
  <MessageMustBePlacedInRangeOfGravEngine>يجب وضعه ضمن نطاق محرك الجاذبية.</MessageMustBePlacedInRangeOfGravEngine>

  <!-- Alerts -->
  <!-- EN: {0} has died from vacuum exposure. -->
  <MessagePlantDiedOfRot_ExposedToVacuum>مات {0} بسبب التعرض للفراغ.</MessagePlantDiedOfRot_ExposedToVacuum>

  <!-- Ancient Vents -->
  <!-- EN: The ancient smoke vents have become active, darkening the sky. -->
  <AncientSmokeVentStartUp>أصبحت فتحات الدخان القديمة نشطة، مما أظلم السماء.</AncientSmokeVentStartUp>
  <!-- EN: The ancient smoke vents are stopping. -->
  <AncientSmokeVentShutdown>فتحات الدخان القديمة تتوقف.</AncientSmokeVentShutdown>
  <!-- EN: The ancient toxic vents have become active, causing toxic fallout. -->
  <AncientToxVentStartUp>أصبحت الفتحات السامة القديمة نشطة، مسببة تساقطاً ساماً.</AncientToxVentStartUp>
  <!-- EN: The ancient toxic vents are stopping. -->
  <AncientToxVentShutdown>الفتحات السامة القديمة تتوقف.</AncientToxVentShutdown>
  <!-- EN: The ancient heat vents have become active, raising temperatures. -->
  <AncientHeatVentStartUp>أصبحت فتحات الحرارة القديمة نشطة، رافعة درجات الحرارة.</AncientHeatVentStartUp>
  <!-- EN: The ancient heat vents are stopping. -->
  <AncientHeatVentShutdown>فتحات الحرارة القديمة تتوقف.</AncientHeatVentShutdown>
  
  <!-- EN: Must be placed over water containing fish. -->
  <CannotPlaceFishingZone>يجب وضعها فوق ماء يحتوي على أسماك.</CannotPlaceFishingZone>
  
  <!-- EN: {TRAP_indefinite} was triggered. -->
  <MessageTrapSprung>تم تفعيل {TRAP_indefinite}.</MessageTrapSprung>

  <!-- EN: {0} is ready to launch again. -->
  <GravshipReadyToLaunch>{0} جاهزة للإطلاق مرة أخرى.</GravshipReadyToLaunch>

  <!-- EN: An orbital scanner has found a signal and is locating its origin -->
  <MessageOrbitalSignalDetected>وجد ماسح مداري إشارة ويحدد مصدرها</MessageOrbitalSignalDetected>
  <!-- EN: completes in {0} -->
  <OrbitalScannerCompletesIn>يكتمل خلال {0}</OrbitalScannerCompletesIn>

  <!-- EN: While talking with {TRADER_nameDef}, {NEGOTIATOR_nameDef} learned of a new quest: {0} -->
  <MessageTraderGaveQuest>أثناء التحدث مع {TRADER_nameDef}، عرف {NEGOTIATOR_nameDef} بمهمة جديدة: {0}</MessageTraderGaveQuest>
  <!-- EN: While reading {BOOK_labelNoParenthesis}, {READER_nameDef} discovered a quest: {0} -->
  <MessageBookGaveQuest>أثناء قراءة {BOOK_labelNoParenthesis}، اكتشف {READER_nameDef} مهمة: {0}</MessageBookGaveQuest>

  <!-- EN: Confirm gravship landing zone to continue. -->
  <MessageConfirmLandingAreaFirst>أكد منطقة هبوط سفينة الجاذبية للمتابعة.</MessageConfirmLandingAreaFirst>
  <!-- EN: Choose a landing site first. -->
  <MessageNoLandingSiteSelected>اختر موقع هبوط أولاً.</MessageNoLandingSiteSelected>
  
  <!-- EN: Cannot store {THING_labelShort} on {TARGET_indefinite} -->
  <CannotStoreThingOnTarget>لا يمكن تخزين {THING_labelShort} على {TARGET_indefinite}</CannotStoreThingOnTarget>

</LanguageData>