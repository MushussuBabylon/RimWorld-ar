  <!-- EN: aim assistance -->
  <AimAssistance.label>مساعدة التصويب</AimAssistance.label>
  <!-- EN: This weapon contains a rudimentary aim assistant computer which helps track targets, increasing accuracy at all ranges. The device can account for environmental challenges, allowing the weapon to ignore the accuracy penalty from bad weather and smoke. -->
