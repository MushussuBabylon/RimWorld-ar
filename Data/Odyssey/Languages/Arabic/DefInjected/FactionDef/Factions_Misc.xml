  <!-- EN: salvagers -->
  <Salvagers.label>الناهبون</Salvagers.label>
  <!-- EN: A ruthless faction of orbital scavengers who scour space for derelict ships and valuable wreckage. Salvagers operate entirely in space. -->
  <Salvagers.description>فصيل قاسٍ من ناهبي المدارات يجوبون الفضاء بحثاً عن السفن المهجورة والحطام القيم. يعمل الناهبون بالكامل في الفضاء.</Salvagers.description>
  <!-- EN: boss -->
  <Salvagers.leaderTitle>زعيم</Salvagers.leaderTitle>
  <!-- EN: {0} from {1} are attacking your {2}. -->
