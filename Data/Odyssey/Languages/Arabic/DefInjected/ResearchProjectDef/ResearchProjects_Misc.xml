    <li>subject_gerund->يبني سفن الجاذبية</li>
 </BasicGravtech.generalRules.rulesStrings>
  
  <!-- EN: beam weapons -->
  <BeamWeapons.label>أسلحة الأشعة</BeamWeapons.label>
  <!-- EN: Construct weapons that use gamma ray beams to burn through armor and ignite targets. -->
  <BeamWeapons.description>بناء أسلحة تستخدم أشعة غاما لاختراق الدروع وإشعال الأهداف.</BeamWeapons.description>
