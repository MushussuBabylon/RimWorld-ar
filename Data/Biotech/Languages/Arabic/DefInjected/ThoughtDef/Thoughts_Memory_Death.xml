<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN: killed a child -->
  <KilledChild.stages.killed_a_child.label>قتل طفلاً</KilledChild.stages.killed_a_child.label>
  <!-- EN: Killing one so young feels wrong, no matter the situation. -->
  <KilledChild.stages.killed_a_child.description>قتل شخص بهذا الصغر يبدو خطأ، مهما كان الموقف.</KilledChild.stages.killed_a_child.description>
  
  <!-- EN: killed my birth mother -->
  <KilledMyBirthMother.stages.killed_my_birth_mother.label>قتلت أمي التي ولدتني</KilledMyBirthMother.stages.killed_my_birth_mother.label>
  
  <!-- EN: my birth mother {0} died -->
  <MyBirthMotherDied.stages.my_birth_mother_died.label>أمي التي ولدتني {0} توفيت</MyBirthMotherDied.stages.my_birth_mother_died.label>
  <!-- EN: My birth mother died. She's gone forever. It's like a hole in my life. -->
  <MyBirthMotherDied.stages.my_birth_mother_died.description>أمي التي ولدتني ماتت. لقد ذهبت إلى الأبد. إنه مثل فجوة في حياتي.</MyBirthMotherDied.stages.my_birth_mother_died.description>
  
  <!-- EN: my birth mother {0} lost -->
  <MyBirthMotherLost.stages.my_birth_mother_lost.label>أمي التي ولدتني {0} فُقدت</MyBirthMotherLost.stages.my_birth_mother_lost.label>
  <!-- EN: My birth mother has been lost. I hope she will get back to us someday. -->
  <MyBirthMotherLost.stages.my_birth_mother_lost.description>لقد فُقدت أمي التي ولدتني. آمل أن تعود إلينا يوماً ما.</MyBirthMotherLost.stages.my_birth_mother_lost.description>
  
</LanguageData>