<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN: always abhorrent -->
  <Execution_Abhorrent.label>مقيت دائماً</Execution_Abhorrent.label>
  <!-- EN: Executing a prisoner is an abhorrent evil under any circumstances. -->
  <Execution_Abhorrent.description>إعدام سجين هو شر مقيت تحت أي ظرف.</Execution_Abhorrent.description>
  <!-- EN: Executed prisoner -->
  <Execution_Abhorrent.comps.2.description>سجين معدوم</Execution_Abhorrent.comps.2.description>
  <!-- EN: Responsible for prisoner death -->
  <Execution_Abhorrent.comps.3.description>مسؤول عن موت سجين</Execution_Abhorrent.comps.3.description>
  <!-- EN: Someone executed a colonist -->
  <Execution_Abhorrent.comps.4.description>شخص ما أعدم مستعمراً</Execution_Abhorrent.comps.4.description>
  <!-- EN: Someone executed a guest -->
  <Execution_Abhorrent.comps.5.description>شخص ما أعدم ضيفاً</Execution_Abhorrent.comps.5.description>
  <!-- EN: Someone executed a prisoner -->
  <Execution_Abhorrent.comps.6.description>شخص ما أعدم سجيناً</Execution_Abhorrent.comps.6.description>
  
  <!-- EN: don't care -->
  <Execution_DontCare.label>لا يهتم</Execution_DontCare.label>
  <!-- EN: Executing prisoners is acceptable, whether they are guilty or innocent. -->
  <Execution_DontCare.description>إعدام السجناء مقبول، سواء كانوا مذنبين أو أبرياء.</Execution_DontCare.description>
  
  <!-- EN: always horrible -->
  <Execution_Horrible.label>مريع دائماً</Execution_Horrible.label>
  <!-- EN: Executing a prisoner is a horrible thing under any circumstances. -->
  <Execution_Horrible.description>إعدام سجين أمر مريع تحت أي ظرف.</Execution_Horrible.description>
  <!-- EN: Executed prisoner -->
  <Execution_Horrible.comps.2.description>سجين معدوم</Execution_Horrible.comps.2.description>
  <!-- EN: Responsible for prisoner death -->
  <Execution_Horrible.comps.3.description>مسؤول عن موت سجين</Execution_Horrible.comps.3.description>
  <!-- EN: Someone executed a colonist -->
  <Execution_Horrible.comps.5.description>شخص ما أعدم مستعمراً</Execution_Horrible.comps.5.description>
  <!-- EN: Someone executed a guest -->
  <Execution_Horrible.comps.6.description>شخص ما أعدم ضيفاً</Execution_Horrible.comps.6.description>
  <!-- EN: Someone executed a prisoner -->
  <Execution_Horrible.comps.7.description>شخص ما أعدم سجيناً</Execution_Horrible.comps.7.description>
  
  <!-- EN: horrible if innocent -->
  <Execution_HorribleIfInnocent.label>مريع إذا كان بريئاً</Execution_HorribleIfInnocent.label>
  <!-- EN: Executing an innocent prisoner is a horrible thing. If the prisoner is guilty, it's acceptable. -->
  <Execution_HorribleIfInnocent.description>إعدام سجين بريء أمر مريع. إذا كان السجين مذنباً، فهو مقبول.</Execution_HorribleIfInnocent.description>
  <!-- EN: Executed innocent prisoner -->
  <Execution_HorribleIfInnocent.comps.2.description>سجين بريء معدوم</Execution_HorribleIfInnocent.comps.2.description>
  <!-- EN: Responsible for innocent prisoner death -->
  <Execution_HorribleIfInnocent.comps.3.description>مسؤول عن موت سجين بريء</Execution_HorribleIfInnocent.comps.3.description>
  <!-- EN: Someone executed a colonist -->
  <Execution_HorribleIfInnocent.comps.5.description>شخص ما أعدم مستعمراً</Execution_HorribleIfInnocent.comps.5.description>
  <!-- EN: Someone executed a guest -->
  <Execution_HorribleIfInnocent.comps.6.description>شخص ما أعدم ضيفاً</Execution_HorribleIfInnocent.comps.6.description>
  <!-- EN: Someone executed a prisoner -->
  <Execution_HorribleIfInnocent.comps.7.description>شخص ما أعدم سجيناً</Execution_HorribleIfInnocent.comps.7.description>
  
  <!-- EN: required -->
  <Execution_Required.label>مطلوب</Execution_Required.label>
  <!-- EN: Prisoners must be executed on a regular basis. When they are, it is a happy occasion. -->
  <Execution_Required.description>يجب إعدام السجناء بشكل منتظم. عندما يحدث ذلك، تكون مناسبة سعيدة.</Execution_Required.description>
  <!-- EN: Executed prisoner -->
  <Execution_Required.comps.2.description>سجين معدوم</Execution_Required.comps.2.description>
  <!-- EN: Responsible for prisoner death -->
  <Execution_Required.comps.3.description>مسؤول عن موت سجين</Execution_Required.comps.3.description>
  <!-- EN: Someone executed a prisoner -->
  <Execution_Required.comps.4.description>شخص ما أعدم سجيناً</Execution_Required.comps.4.description>
  <!-- EN: Someone executed a guest -->
  <Execution_Required.comps.5.description>شخص ما أعدم ضيفاً</Execution_Required.comps.5.description>
  <!-- EN: No execution for {MINDAYSLASTEXECUTION} days -->
  <Execution_Required.comps.6.description>لا إعدام لمدة {MINDAYSLASTEXECUTION} أيام</Execution_Required.comps.6.description>
  <!-- EN: executed someone -->
  <Execution_Required.comps.7.eventLabel>أعدم شخصاً</Execution_Required.comps.7.eventLabel>
  
  <!-- EN: respected if guilty -->
  <Execution_RespectedIfGuilty.label>محترم إذا كان مذنباً</Execution_RespectedIfGuilty.label>
  <!-- EN: Executing prisoners is acceptable. If the prisoner is guilty, it is cause for great happiness. -->
  <Execution_RespectedIfGuilty.description>إعدام السجناء مقبول. إذا كان السجين مذنباً، فهو مدعاة لسعادة عظيمة.</Execution_RespectedIfGuilty.description>
  <!-- EN: executed someone -->
  <Execution_RespectedIfGuilty.comps.3.eventLabel>أعدم شخصاً</Execution_RespectedIfGuilty.comps.3.eventLabel>
  
