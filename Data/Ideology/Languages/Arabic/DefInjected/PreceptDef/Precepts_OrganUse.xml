<LanguageData>
  
  <!-- EN: totally abhorrent -->
  <OrganUse_Abhorrent.label>مقيت تماماً</OrganUse_Abhorrent.label>
  <!-- EN: Any harvesting, trading, or installing natural organs is an abhorrent evil. -->
  <OrganUse_Abhorrent.description>أي حصاد أو تجارة أو تركيب للأعضاء الطبيعية هو شر مقيت.</OrganUse_Abhorrent.description>
  <!-- EN: Someone harvested an organ -->
  <OrganUse_Abhorrent.comps.2.description>شخص ما حصد عضواً</OrganUse_Abhorrent.comps.2.description>
  <!-- EN: Someone traded an organ -->
  <OrganUse_Abhorrent.comps.5.description>شخص ما تاجر بعضو</OrganUse_Abhorrent.comps.5.description>
  <!-- EN: Someone installed an organ -->
  <OrganUse_Abhorrent.comps.8.description>شخص ما ركب عضواً</OrganUse_Abhorrent.comps.8.description>
  
  <!-- EN: acceptable -->
  <OrganUse_Acceptable.label>مقبول</OrganUse_Acceptable.label>
  <!-- EN: It's okay to harvest, buy, install, or sell organs. -->
  <OrganUse_Acceptable.description>لا بأس بحصاد أو شراء أو تركيب أو بيع الأعضاء.</OrganUse_Acceptable.description>
  
  <!-- EN: no harvest or sell -->
  <OrganUse_HorribleNoSell.label>لا حصاد ولا بيع</OrganUse_HorribleNoSell.label>
  <!-- EN: Harvesting organs is a horrible thing. Selling any natural organ is pretty bad too. However, it's okay to buy and install them. -->
  <OrganUse_HorribleNoSell.description>حصاد الأعضاء أمر مريع. بيع أي عضو طبيعي سيء للغاية أيضاً. ومع ذلك، لا بأس بشرائها وتركيبها.</OrganUse_HorribleNoSell.description>
  <!-- EN: Someone harvested an organ -->
  <OrganUse_HorribleNoSell.comps.2.description>شخص ما حصد عضواً</OrganUse_HorribleNoSell.comps.2.description>
  <!-- EN: Someone sold an organ -->
  <OrganUse_HorribleNoSell.comps.4.description>شخص ما باع عضواً</OrganUse_HorribleNoSell.comps.4.description>
  
  <!-- EN: no harvest -->
  <OrganUse_HorribleSellOK.label>لا حصاد</OrganUse_HorribleSellOK.label>
  <!-- EN: Harvesting organs is a horrible thing. However, it's okay to buy, install, or sell them. -->
  <OrganUse_HorribleSellOK.description>حصاد الأعضاء أمر مريع. ومع ذلك، لا بأس بشرائها أو تركيبها أو بيعها.</OrganUse_HorribleSellOK.description>
  <!-- EN: Someone harvested an organ -->
  <OrganUse_HorribleSellOK.comps.2.description>شخص ما حصد عضواً</OrganUse_HorribleSellOK.comps.2.description>
  
