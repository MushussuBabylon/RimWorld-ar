<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN: spark slave rebellion -->
  <SparkSlaveRebellion.label>إشعال تمرد العبيد</SparkSlaveRebellion.label>
  <!-- EN:
    <li>r_logentry->[INITIATOR_nameDef] suggested they make a break for it.</li>
    <li>r_logentry->[INITIATOR_nameDef] encouraged [RECIPIENT_nameDef] to take back [RECIPIENT_possessive] freedom.</li>
    <li>r_logentry->[INITIATOR_nameDef] spoke of ending their enslavement and making a break for it.</li>
    <li>r_logentry->[INITIATOR_nameDef] spoke of a life beyond servitude and encouraged [RECIPIENT_nameDef] to escape.</li>
    <li>r_logentry->[INITIATOR_nameDef] whispered that security was lax and now would be a good time to escape.</li>
  -->
  <SparkSlaveRebellion.logRulesInitiator.rulesStrings>
    <li>r_logentry->اقترح [INITIATOR_nameDef] أن يحاولوا الهرب.</li>
    <li>r_logentry->شجع [INITIATOR_nameDef] [RECIPIENT_nameDef] على استعادة حري[RECIPIENT_possessive].</li>
    <li>r_logentry->تحدث [INITIATOR_nameDef] عن إنهاء استعبادهم والهرب.</li>
    <li>r_logentry->تحدث [INITIATOR_nameDef] عن حياة تتجاوز العبودية وشجع [RECIPIENT_nameDef] على الهرب.</li>
    <li>r_logentry->همس [INITIATOR_nameDef] بأن الحراسة متراخية وأن الوقت مناسب للهرب.</li>
 </SparkSlaveRebellion.logRulesInitiator.rulesStrings>
  
  <!-- EN: suppress -->
  <Suppress.label>قمع</Suppress.label>
  <!-- EN:
    <li>r_logentry->[INITIATOR_nameDef] told [RECIPIENT_nameDef] there would be punishments for rebellion.</li>
    <li>r_logentry->[INITIATOR_nameDef] warned [RECIPIENT_nameDef] that disobedience would be punished.</li>
    <li>r_logentry->[INITIATOR_nameDef] cautioned [RECIPIENT_nameDef] against infractions of any kind.</li>
    <li>r_logentry->[INITIATOR_nameDef] suggested that [RECIPIENT_nameDef] follow orders and not ask questions.</li>
  -->
  <Suppress.logRulesInitiator.rulesStrings>
    <li>r_logentry->أخبر [INITIATOR_nameDef] [RECIPIENT_nameDef] أنه ستكون هناك عقوبات على التمرد.</li>
    <li>r_logentry->حذر [INITIATOR_nameDef] [RECIPIENT_nameDef] من أن العصيان سيعاقب.</li>
    <li>r_logentry->نبه [INITIATOR_nameDef] [RECIPIENT_nameDef] من أي نوع من المخالفات.</li>
    <li>r_logentry->اقترح [INITIATOR_nameDef] أن يتبع [RECIPIENT_nameDef] الأوامر ولا يسأل.</li>
 </Suppress.logRulesInitiator.rulesStrings>
  
</LanguageData>