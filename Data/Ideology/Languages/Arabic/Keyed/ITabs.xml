<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>

  <!-- Character -->
  <!-- EN: Overrides some precepts related to -->
  <OverridesSomePrecepts>يتجاوز بعض الوصايا المتعلقة بـ</OverridesSomePrecepts>
  <!-- EN: Agrees with memes -->
  <AgreeableMemes>يتوافق مع الميمات</AgreeableMemes>
  <!-- EN: Conflicts with memes -->
  <DisagreeableMemes>يتعارض مع الميمات</DisagreeableMemes>

  <!-- ITab titles -->
  <!-- EN: Slave -->
  <TabSlave>عبد</TabSlave>
  <!-- EN: The faction goodwill you will gain if you release a slave. This is affected by the slaves's physical and mental health. -->
  <SlaveReleaseRelationGainsDesc>حسن النية الذي ستكسبه من الفصيل إذا أطلقت سراح عبد. يتأثر ذلك بحالته الصحية الجسدية والعقلية.</SlaveReleaseRelationGainsDesc>
  <!-- EN: Relations gain on release -->
  <SlaveReleasePotentialRelationGains>مكاسب العلاقات عند الإطلاق</SlaveReleasePotentialRelationGains>
  <!-- EN: Slave rebellion interval -->
  <SlaveRebellionMTBDays>فترة تمرد العبيد</SlaveRebellionMTBDays>
  <!-- EN: The average number of days between slave rebellion attempts. Only time awake is counted. This is affected by suppression, mood, health, proximity to weapons, the number of slaves on the map, and the presence of colonists on the map. -->
  <SlaveRebellionMTBDaysDescription>متوسط عدد الأيام بين محاولات تمرد العبيد. يُحتسب وقت الاستيقاظ فقط. يتأثر هذا بالكبت، والمزاج، والصحة، والقرب من الأسلحة، وعدد العبيد على الخريطة، ووجود المستعمرين على الخريطة.</SlaveRebellionMTBDaysDescription>

  <!-- Slave tab -->
  <!-- EN: Suppression -->
  <Suppression>الكبت</Suppression>
  <!-- EN: Suppression is the psychological effect of fear and control on a slave. If suppression is low, slaves are more likely to rebel. -->
  <SuppressionDesc>الكبت هو الأثر النفسي للخوف والسيطرة على العبد. إذا كان الكبت منخفضاً، يزداد احتمال تمرد العبيد.</SuppressionDesc>
  <!-- EN: Suppression fall rate -->
  <SuppressionFallRate>معدل انخفاض الكبت</SuppressionFallRate>
  <!-- EN: Suppression falls over time depending on its current level:\n\n- {1}+ suppression: {0} per day\n- {4}-{3} suppression: {2} per day\n- {6}- suppression: {5} per day\n\nApparel and terror can also affect the suppression fall rate. This slave's fall rate calculation is -->
  <SuppressionFallRateDesc>ينخفض الكبت بمرور الوقت حسب مستواه الحالي:\n\n- كبت {1}+: {0} في اليوم\n- كبت {4}-{3}: {2} في اليوم\n- كبت {6}-: {5} في اليوم\n\nيمكن أن تؤثر الملابس والرعب أيضاً على معدل انخفاض الكبت. حساب معدل الانخفاض لهذا العبد هو</SuppressionFallRateDesc>
  <!-- EN: Cannot emancipate -->
  <CannotEmancipate>لا يمكن التحرير</CannotEmancipate>
  <!-- EN: Cannot imprison -->
  <CannotImprison>لا يمكن السجن</CannotImprison>
  <!-- EN: Current suppression -->
  <CurrentSuppression>الكبت الحالي</CurrentSuppression>
  <!-- EN: Terror -->
  <Terror>الرعب</Terror>
  <!-- EN: Terror is a way to keep slaves suppressed. It rises when the slave spends time near terrifying things like terror sculptures. A slave can only be affected by three terror sources at a time.\n\nWhile terror is high, suppression falls slower as follows -->
  <TerrorDescription>الرعب وسيلة لإبقاء العبيد مكبوتين. يزداد عندما يقضي العبد وقتاً بالقرب من أشياء مرعبة مثل منحوتات الرعب. يمكن أن يتأثر العبد بثلاثة مصادر رعب فقط في المرة الواحدة.\n\nبينما يكون الرعب مرتفعاً، ينخفض الكبت ببطء أكبر على النحو التالي</TerrorDescription>
  <!-- EN: Recent terrifying observations -->
  <TerrorCurrentThoughts>ملاحظات مرعبة حديثة</TerrorCurrentThoughts>

  <!-- EN: Base interval -->
  <SuppressionBaseInterval>الفاصل الأساسي</SuppressionBaseInterval>
  <!-- EN: Moving capacity -->
  <SuppressionMovingCapacityFactor>قدرة الحركة</SuppressionMovingCapacityFactor>
  <!-- EN: Suppression -->
  <SuppressionFactor>الكبت</SuppressionFactor>
  <!-- EN: Mood -->
  <SuppressionMoodFactor>المزاج</SuppressionMoodFactor>
  <!-- EN: Slave count -->
  <SuppressionSlaveCountFactor>عدد العبيد</SuppressionSlaveCountFactor>
  <!-- EN: Escape route -->
  <SuppressionEscapeFactor>طريق الهروب</SuppressionEscapeFactor>
  <!-- EN: Weapon proximity -->
  <SuppressionWeaponProximityFactor>القرب من الأسلحة</SuppressionWeaponProximityFactor>
  <!-- EN: Final interval -->
  <SuppressionFinalInterval>الفاصل النهائي</SuppressionFinalInterval>
  <!-- EN: Unattended -->
  <SuppressionUnattendedByColonists>غير مراقب</SuppressionUnattendedByColonists>
  <!-- EN: At least one of the {0} slaves on this map is expected rebel on average every {1}. -->
  <SuppressionRebellionAnySlave>من المتوقع أن يتمرد عبد واحد على الأقل من بين {0} عبداً على هذه الخريطة بمعدل كل {1}.</SuppressionRebellionAnySlave>

  <!-- EN: Will -->
  <WillLevel>الإرادة</WillLevel>
  <!-- EN: How much the prisoner is determined not to submit. When this reaches zero, they can be enslaved. -->
  <WillLevelDesc>مدى إصرار السجين على عدم الخضوع. عندما يصل هذا إلى الصفر، يمكن استعباده.</WillLevelDesc>
  <!-- EN: {0} base will -->
  <WillFromPawnKind>إرادة أساسية {0}</WillFromPawnKind>
  <!-- EN: Target ideoligion -->
  <IdeoConversionTarget>العقيدة المستهدفة</IdeoConversionTarget>
  <!-- EN: The ideoligion your wardens will attempt to convert this prisoner to. -->
  <IdeoConversionTargetDesc>العقيدة التي سيحاول سجّانوك تحويل هذا السجين إليها.</IdeoConversionTargetDesc>

  <!-- Social -->
  <!-- EN: Change per day due to mood -->
  <CertaintyChangePerDay>التغير اليومي بسبب المزاج</CertaintyChangePerDay>
  <!-- EN: Change rate based on mood -->
  <MoodChangeRate>معدل التغير بناءً على المزاج</MoodChangeRate>
  <!-- EN: {PAWN_nameDef}'s certainty in {IDEO_name} -->
  <CertaintyInIdeo>يقين {PAWN_nameDef} في {IDEO_name}</CertaintyInIdeo>
  <!-- EN: A special status this person holds in their ideoligion. If you change or take away this role, they will become unhappy. -->
  <RoleDesc>مكانة خاصة يحملها هذا الشخص في عقيدته. إذا غيرت أو أزلت هذا الدور، سيصبح غير سعيد.</RoleDesc>
  <!-- EN: Changing roles requires a role change ritual. Select any ritual spot or altar and press 'Begin role change'. -->
  <RoleAssignmentTip>تغيير الأدوار يتطلب طقس تغيير الأدوار. اختر أي بقعة طقس أو مذبح واضغط 'ابدأ تغيير الدور'.</RoleAssignmentTip>
  <!-- EN: Conversion attempts will be weaker because of trait/meme agreement -->
  <ConversionWeakerDueToTraitAgreements>ستكون محاولات التحويل أضعف بسبب توافق السمة/الميم</ConversionWeakerDueToTraitAgreements>
  <!-- EN: Conversion attempts will be stronger because of trait/meme conflict -->
  <ConversionStrongerDueToTraitAgreements>ستكون محاولات التحويل أقوى بسبب تعارض السمة/الميم</ConversionStrongerDueToTraitAgreements>

  <!-- EN: Cut -->
  <Cut>قطع</Cut>
  <!-- EN: Cut both eyes -->
  <CutBothEyes>قطع كلتا العينين</CutBothEyes>

