<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- Heritage -->
  <!-- EN: Choose a new heir for {HOLDER_nameIndef}: -->
  <ChooseHeir>اختر وريثاً جديداً لـ {HOLDER_nameIndef}:</ChooseHeir>
  <!-- EN: You're about to change the heir of the title {HOLDER_nameIndef} received from {0_name}. This requires building a monument in a limited time, to consecrate the new inheritance. -->
  <MakeHeirConfirm>أنت على وشك تغيير وريث اللقب الذي حصل عليه {HOLDER_nameIndef} من {0_name}. هذا يتطلب بناء نصب تذكاري في وقت محدود، لتكريس الوراثة الجديدة.</MakeHeirConfirm>
  <!-- EN: This will upset {HOLDER_possessive} current heir {HEIR_nameFull}. -->
  <MakeHeirPreviousHeirWarning>هذا سيزعج وريث {HOLDER_possessive} الحالي {HEIR_nameFull}.</MakeHeirPreviousHeirWarning>

  <!-- Call aid -->
  <!-- EN: Call aid... -->
  <CommandCallRoyalAid>طلب المساعدة...</CommandCallRoyalAid>
  <!-- EN: Call for aid using a special permit.\n\nEach type of aid may be used for free once, after which you must wait to use it for free again. You can use the aid more frequently, but it costs honor to do so. -->
  <CommandCallRoyalAidDesc>طلب المساعدة باستخدام إذن خاص.\n\nيمكن استخدام كل نوع من المساعدة مجاناً مرة واحدة، وبعد ذلك يجب الانتظار لاستخدامها مجاناً مرة أخرى. يمكنك استخدام المساعدة بشكل أكثر تكراراً، لكن ذلك يكلف شرفاً.</CommandCallRoyalAidDesc>
  <!-- EN: Guests will not use their aid permits. -->
  <CommandCallRoyalAidLodger>لن يستخدم الضيوف أذونات المساعدة الخاصة بهم.</CommandCallRoyalAidLodger>
  <!-- EN: Slaves cannot use their permits. -->
  <CommandCallRoyalAidSlave>لا يمكن للعبيد استخدام أذوناتهم.</CommandCallRoyalAidSlave>
  <!-- EN: Your relations with {FACTION_name} are hostile. -->
  <CommandCallRoyalAidFactionHostile>علاقاتك مع {FACTION_name} معادية.</CommandCallRoyalAidFactionHostile>
  <!-- EN: Free -->
  <CommandCallRoyalAidFreeOption>مجاني</CommandCallRoyalAidFreeOption>
  <!-- EN: {0} days left, costs {1} {FACTION_royalFavorLabel} -->
  <CommandCallRoyalAidFavorOption>متبقي {0} يوم، يكلف {1} {FACTION_royalFavorLabel}</CommandCallRoyalAidFavorOption>
  <!-- EN: You are about to call for aid, but there are people from factions whom {0_name} is not hostile to. Any soldiers you call will not attack them: {1} -->
  <CommandCallRoyalAidWarningNonHostileFactions>أنت على وشك طلب المساعدة، لكن هناك أشخاص من فصائل لا يعاديهم {0_name}. أي جنود تستدعيهم لن يهاجموهم: {1}</CommandCallRoyalAidWarningNonHostileFactions>
  <!-- EN: Not enough honor. -->
  <CommandCallRoyalAidNotEnoughFavor>لا يوجد شرف كافٍ.</CommandCallRoyalAidNotEnoughFavor>
  <!-- EN: {FACTION_name} cannot reach this area. -->
  <CommandCallRoyalAidMapUnreachable>{FACTION_name} لا يمكنه الوصول إلى هذه المنطقة.</CommandCallRoyalAidMapUnreachable>
  <!-- EN: Cannot call aid here. -->
  <CommandCallRoyalAidInvalidMap>لا يمكن طلب المساعدة هنا.</CommandCallRoyalAidInvalidMap>
  
  <!-- Call laborers -->
  <!-- EN: Call laborers -->
  <CommandCallLaborers>استدعاء عمال</CommandCallLaborers>
  <!-- EN: Use a special permit to call for a group of laborers from your ally. These workers can only do labor tasks, but you can control them like they were your own colonists. You are required to keep them safe. -->
  <CommandCallLaborersDesc>استخدم إذناً خاصاً لاستدعاء مجموعة من العمال من حليفك. يمكن لهؤلاء العمال القيام بمهام العمل فقط، لكن يمكنك التحكم بهم كما لو كانوا مستعمرين خاصين بك. أنت مطالب بالحفاظ على سلامتهم.</CommandCallLaborersDesc>
  <!-- EN: On cooldown. {0} days left. -->
  <CommandOnCooldown>قيد فترة تهدئة. متبقي {0} يوم.</CommandOnCooldown>
  <!-- EN: {0} laborers -->
  <CommandCallLaborersNumLaborers>{0} عامل</CommandCallLaborersNumLaborers>

  <!-- Abilities -->
  <!-- EN: Neural heat would overflow. Disable the neural heat limiter to cast. -->
  <CommandPsycastWouldExceedEntropy>ستفيض الحرارة العصبية. عطل محدد الحرارة العصبية للإلقاء.</CommandPsycastWouldExceedEntropy>
  <!-- EN: {PSYCASTNAME} consumes {0} psyfocus but {CASTERNAME} only has {1}. -->
  <CommandPsycastNotEnoughPsyfocus>يستهلك {PSYCASTNAME} {0} تركيز نفسي لكن {CASTERNAME} لديه {1} فقط.</CommandPsycastNotEnoughPsyfocus>
  <!-- EN: {PSYCASTNAME} needs {0} psyfocus to stop {1}'s mental break but {CASTERNAME} only has {2} psyfocus. -->
  <CommandPsycastNotEnoughPsyfocusForMentalBreak>يحتاج {PSYCASTNAME} إلى {0} تركيز نفسي لإيقاف انهيار {1} النفسي لكن {CASTERNAME} لديه {2} تركيز نفسي فقط.</CommandPsycastNotEnoughPsyfocusForMentalBreak>
  <!-- EN: level {0} psylink is required. -->
  <CommandPsycastHigherLevelPsylinkRequired>مستوى الرابط النفسي {0} مطلوب.</CommandPsycastHigherLevelPsylinkRequired>
  <!-- EN: Zero psychic sensitivity. -->
  <CommandPsycastZeroPsychicSensitivity>حساسية نفسية صفرية.</CommandPsycastZeroPsychicSensitivity>
  <!-- EN: Ability user is unconscious. -->
  <CommandPsycastPawnIsUnconscious>مستخدم القدرة فاقد الوعي.</CommandPsycastPawnIsUnconscious>
  <!-- EN: Need at least {0} psyfocus to cast this. -->
  <CommandPsycastLowPsyfocus>تحتاج على الأقل {0} تركيز نفسي لإلقاء هذا.</CommandPsycastLowPsyfocus>
  <!-- EN: Psychic insanity immune. -->
  <CommandPsycastInsanityImmune>محصن ضد الجنون النفسي.</CommandPsycastInsanityImmune>
  <!-- EN: H -->
  <NeuralHeatLetter>ح</NeuralHeatLetter>
  <!-- EN: P -->
  <PsyfocusLetter>ت</PsyfocusLetter>
  <!-- EN: Psychic insanity immune -->
  <IneffectivePsychicImmune>محصن ضد الجنون النفسي</IneffectivePsychicImmune>

  <!-- Select monument marker -->
  <!-- EN: Select monument -->
  <CommandSelectMonumentMarker>اختر النصب</CommandSelectMonumentMarker>
  <!-- EN: Select the monument marker this belongs to. -->
  <CommandSelectMonumentMarkerDesc>اختر علامة النصب التي ينتمي إليها هذا.</CommandSelectMonumentMarkerDesc>

  <!-- Warn in building radius -->
  <!-- EN: Build radius warning -->
  <CommandWarnInBuildingRadius>تحذير نطاق البناء</CommandWarnInBuildingRadius>
  <!-- EN: If enabled, this object will draw a red line to buildings you are placing using the architect menu, if they would interfere with meditation due to being too close.\n\nYou can turn this off if you don't intend to use this for meditation. -->
  <CommandWarnInBuildingRadiusDesc>إذا تم تفعيله، سيرسم هذا الكائن خطاً أحمر إلى المباني التي تضعها باستخدام قائمة المعماري، إذا كانت ستتداخل مع التأمل بسبب قربها الشديد.\n\nيمكنك إيقاف هذا إذا كنت لا تنوي استخدام هذا للتأمل.</CommandWarnInBuildingRadiusDesc>
  
  <!-- Permits -->
  <!-- EN: Choose permit -->
  <ChooseRoyalPermit>اختر إذناً</ChooseRoyalPermit>
  <!-- EN: Open the permit selection screen and choose a new permit. -->
  <ChooseRoyalPermit_Desc>افتح شاشة اختيار الإذن واختر إذناً جديداً.</ChooseRoyalPermit_Desc>

  <!-- EN: Leave bestowing ceremony -->
  <CommandLeaveBestowingCeremony>مغادرة حفل المنح</CommandLeaveBestowingCeremony>
  <!-- EN: Stop participating in the bestowing ceremony. -->
  <CommandLeaveBestowingCeremonyDesc>التوقف عن المشاركة في حفل المنح.</CommandLeaveBestowingCeremonyDesc>
  <!-- EN: Cancel bestowing ceremony -->
  <CommandCancelBestowingCeremony>إلغاء حفل المنح</CommandCancelBestowingCeremony>
  <!-- EN: End the bestowing ceremony immediately. The bestower will leave, but another opportunity to perform the ceremony will arise soon. -->
  <CommandCancelBestowingCeremonyDesc>إنهاء حفل المنح فوراً. سيغادر المانح، لكن فرصة أخرى لأداء الحفل ستظهر قريباً.</CommandCancelBestowingCeremonyDesc>
  <!-- EN: Are you sure you want to cancel bestowing ceremony? -->
  <CommandCancelBestowingCeremonyConfirm>هل أنت متأكد أنك تريد إلغاء حفل المنح؟</CommandCancelBestowingCeremonyConfirm>
</LanguageData>