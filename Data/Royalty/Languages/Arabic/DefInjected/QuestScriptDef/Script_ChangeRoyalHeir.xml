<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN:
    <li>questDescription->\nIn order to consecrate making [titleHeir_nameFull] the heir of [titleHolder_nameFull]'s title, you must build a monument.\n\nThe monument will be [monumentSize] in size and will require these resources (total value [monumentRequiredResourcesMarketValue_money]):\n\n[monumentRequiredResources]\n\nFailing to finish the monument within 20 days is considered to profane the ritual. Your relations with [asker_factionName] will fall by 25, and the heir will not be changed.\n\nIf the monument is destroyed within [keepMonumentTicks_duration] days after completion, your relations with [asker_factionName] will fall by [goodwillChangeIfMonumentDestroyed].</li>
  -->
  <ChangeRoyalHeir.questDescriptionRules.rulesStrings>
    <li>questDescription->\nلتكريس جعل [titleHeir_nameFull] وريثاً للقب [titleHolder_nameFull]، يجب عليك بناء نصب تذكاري.\n\nسيكون حجم النصب [monumentSize] وسيتطلب هذه الموارد (القيمة الإجمالية [monumentRequiredResourcesMarketValue_money]):\n\n[monumentRequiredResources]\n\nيعتبر عدم إنهاء النصب خلال 20 يوماً تدنيساً للطقس. ستنخفض علاقاتك مع [asker_factionName] بمقدار 25، ولن يتم تغيير الوريث.\n\nإذا تم تدمير النصب خلال [keepMonumentTicks_duration] يوم بعد الإكمال، ستنخفض علاقاتك مع [asker_factionName] بمقدار [goodwillChangeIfMonumentDestroyed].</li>
 </ChangeRoyalHeir.questDescriptionRules.rulesStrings>
  <!-- EN:
    <li>questName->[titleHeir_nameDef]'s inheritance</li>
  -->
  <ChangeRoyalHeir.questNameRules.rulesStrings>
    <li>questName->ميراث [titleHeir_nameDef]</li>
 </ChangeRoyalHeir.questNameRules.rulesStrings>
  <!-- EN: Time left: {0} -->
  <ChangeRoyalHeir.InspectStringTimeLeft.slateRef>الوقت المتبقي: {0}</ChangeRoyalHeir.InspectStringTimeLeft.slateRef>
  <!-- EN: [titleHolder_nameDef]'s heir change failed -->
  <ChangeRoyalHeir.LetterTextAskerOffended.slateRef>فشل تغيير وريث [titleHolder_nameDef]</ChangeRoyalHeir.LetterTextAskerOffended.slateRef>
  <!-- EN: [asker_nameDef] is offended that you promised to consecrate the new inheritance, but did not build the monument within the prescribed time.\n\nYou lost 25 goodwill with [asker_faction_name]. -->
  <ChangeRoyalHeir.LetterLabelAskerOffended.slateRef>شعر [asker_nameDef] بالإهانة لأنك وعدت بتكريس الميراث الجديد، لكنك لم تقم ببناء النصب في الوقت المحدد.\n\nلقد فقدت 25 من حسن النية مع [asker_faction_name].</ChangeRoyalHeir.LetterLabelAskerOffended.slateRef>
  <!-- EN: Title holder died: {SUBJECT_definite} -->
  <ChangeRoyalHeir.LetterLabelTitleHolderDied.slateRef>توفي حامل اللقب: {SUBJECT_definite}</ChangeRoyalHeir.LetterLabelTitleHolderDied.slateRef>
  <!-- EN: {SUBJECT_definite}, whose heir was in the process of being changed, has died. -->
  <ChangeRoyalHeir.LetterTextTitleHolderDied.slateRef>توفي {SUBJECT_definite}، الذي كان وريثه قيد التغيير.</ChangeRoyalHeir.LetterTextTitleHolderDied.slateRef>
  <!-- EN: Designated heir died: {SUBJECT_definite} -->
  <ChangeRoyalHeir.LetterLabelDesignatedHeirDied.slateRef>توفي الوريث المعين: {SUBJECT_definite}</ChangeRoyalHeir.LetterLabelDesignatedHeirDied.slateRef>
  <!-- EN: {SUBJECT_definite}, who was supposed to become heir to a title, has died. -->
  <ChangeRoyalHeir.LetterTextDesignatedHeirDied.slateRef>توفي {SUBJECT_definite}، الذي كان من المفترض أن يصبح وريثاً للقب.</ChangeRoyalHeir.LetterTextDesignatedHeirDied.slateRef>
  <!-- EN: Monument destroyed -->
  <ChangeRoyalHeir.LetterLabelMonumentDestroyed.slateRef>نصب مُدمر</ChangeRoyalHeir.LetterLabelMonumentDestroyed.slateRef>
  <!-- EN: [asker_nameDef] is offended that you promised to consecrate the new inheritance, but allowed the monument to be ruined soon after completion.\n\nYour relations with [asker_faction_name] have fallen by [goodwillChangeIfMonumentDestroyed]. -->
  <ChangeRoyalHeir.LetterTextMonumentDestroyed.slateRef>شعر [asker_nameDef] بالإهانة لأنك وعدت بتكريس الميراث الجديد، لكنك سمحت بتخريب النصب بعد إكماله بفترة وجيزة.\n\nلقد انخفضت علاقاتك مع [asker_faction_name] بمقدار [goodwillChangeIfMonumentDestroyed].</ChangeRoyalHeir.LetterTextMonumentDestroyed.slateRef>
  <!-- EN: New heir: [titleHeir_nameDef] -->
  <ChangeRoyalHeir.LetterLabelNewHeir.slateRef>وريث جديد: [titleHeir_nameDef]</ChangeRoyalHeir.LetterLabelNewHeir.slateRef>
  <!-- EN: [titleHeir_nameDef] is the new heir of [titleHolder_nameDef]. -->
  <ChangeRoyalHeir.LetterTextNewHeir.slateRef>[titleHeir_nameDef] هو الوريث الجديد لـ[titleHolder_nameDef].</ChangeRoyalHeir.LetterTextNewHeir.slateRef>
  <!-- EN: Do not destroy the monument for {0} -->
  <ChangeRoyalHeir.DontDestroyMonumentForDays.slateRef>لا تدمر النصب لمدة {0}</ChangeRoyalHeir.DontDestroyMonumentForDays.slateRef>
  <!-- EN: Do not destroy the monument for {0} -->
  <ChangeRoyalHeir.DontDestroyMonumentForDaysTip.slateRef>لا تدمر النصب لمدة {0}</ChangeRoyalHeir.DontDestroyMonumentForDaysTip.slateRef>
  <!-- EN: Keep monument {0} -->
  <ChangeRoyalHeir.KeepMonument.slateRef>حافظ على النصب {0}</ChangeRoyalHeir.KeepMonument.slateRef>
  
</LanguageData>