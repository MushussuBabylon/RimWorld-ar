    <li>desc_sentence->[Quantity_adjphrase] [PersonJob] يرقصون.</li>
    <li>desc_sentence->[Quantity_adjphrase] [Animal] يستمعون بانتباه.</li>
 </AttendedConcert.rulePack.rulesStrings>
  
