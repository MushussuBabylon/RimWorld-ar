  <!-- EN: attended concert -->
  <AttendedConcert.label>حضر حفلة موسيقية</AttendedConcert.label>
  <!-- EN:
    <li>tale_noun->[ATTENDER_nameDef] attending [ORGANIZER_nameDef]'s concert</li>
