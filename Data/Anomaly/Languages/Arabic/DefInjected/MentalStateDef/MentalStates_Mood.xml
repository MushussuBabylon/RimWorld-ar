<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN: dark visions -->
  <DarkVisions.label>رؤى مظلمة</DarkVisions.label>
  <!-- EN: Mental state: Dark visions -->
  <DarkVisions.baseInspectLine>حالة عقلية: رؤى مظلمة</DarkVisions.baseInspectLine>
  <!-- EN: {PAWN_nameDef} has become overwhelmed with horrible visions, rambling about things that only {PAWN_pronoun} can see. {PAWN_pronoun} will snap out of it in a few hours. -->
  <DarkVisions.beginLetter>غمرت {PAWN_nameDef} رؤى مروعة، يهذي بأشياء لا يراها إلا {PAWN_pronoun}. سيفيق منها {PAWN_pronoun} خلال ساعات قليلة.</DarkVisions.beginLetter>
  <!-- EN: dark visions -->
  <DarkVisions.beginLetterLabel>رؤى مظلمة</DarkVisions.beginLetterLabel>
  <!-- EN: {PAWN_nameDef}'s dark visions have stopped. -->
  <DarkVisions.recoveryMessage>توقفت رؤى {PAWN_nameDef} المظلمة.</DarkVisions.recoveryMessage>
  
  <!-- EN: entity slayer -->
  <EntityKiller.label>قاتل كيانات</EntityKiller.label>
  <!-- EN: Mental state: Entity slayer -->
  <EntityKiller.baseInspectLine>حالة عقلية: قاتل كيانات</EntityKiller.baseInspectLine>
  <!-- EN: {0} has snapped. {PAWN_pronoun} can no longer tolerate holding such dangerous entities in captivity and intends to destroy as many as {PAWN_pronoun} can. -->
  <EntityKiller.beginLetter>انهار {0}. لم يعد {PAWN_pronoun} قادرًا على تحمل احتجاز كيانات بهذه الخطورة، وينوي تدمير أكبر عدد ممكن منها {PAWN_pronoun}.</EntityKiller.beginLetter>
  <!-- EN: {0} is no longer slaughtering random entities. -->
  <EntityKiller.recoveryMessage>لم يعد {0} يذبح الكيانات العشوائية.</EntityKiller.recoveryMessage>
  
  <!-- EN: entity liberator -->
  <EntityLiberator.label>محرر كيانات</EntityLiberator.label>
  <!-- EN: Mental state: Entity liberator -->
  <EntityLiberator.baseInspectLine>حالة عقلية: محرر كيانات</EntityLiberator.baseInspectLine>
  <!-- EN: {0} has become suddenly allured by a captive entity and is convinced it must be freed. -->
  <EntityLiberator.beginLetter>أصبح {0} فجأة مفتونًا بكيان أسير، وهو مقتنع بضرورة تحريره.</EntityLiberator.beginLetter>
  <!-- EN: {0} is no longer freeing entities. -->
  <EntityLiberator.recoveryMessage>لم يعد {0} يحرر الكيانات.</EntityLiberator.recoveryMessage>
  
  <!-- EN: insane ramblings -->
  <InsaneRamblings.label>هذيانات جنونية</InsaneRamblings.label>
  <!-- EN: Mental state: Insane ramblings -->
  <InsaneRamblings.baseInspectLine>حالة عقلية: هذيانات جنونية</InsaneRamblings.baseInspectLine>
  <!-- EN: {PAWN_nameDef} has become completely untethered from reality, ranting about impossible subjects. {PAWN_pronoun} will snap out of it in a few hours. -->
  <InsaneRamblings.beginLetter>انفصل {PAWN_nameDef} تمامًا عن الواقع، يصيح بمواضيع مستحيلة. سيفيق منها {PAWN_pronoun} خلال ساعات قليلة.</InsaneRamblings.beginLetter>
  <!-- EN: insane ramblings -->
  <InsaneRamblings.beginLetterLabel>هذيانات جنونية</InsaneRamblings.beginLetterLabel>
  <!-- EN: {PAWN_nameDef} has stopped rambling. -->
  <InsaneRamblings.recoveryMessage>توقف {PAWN_nameDef} عن الهذيان.</InsaneRamblings.recoveryMessage>
  
  <!-- EN: terrifying hallucinations -->
  <TerrifyingHallucinations.label>هلوسات مرعبة</TerrifyingHallucinations.label>
  <!-- EN: Mental state: Terrifying hallucinations -->
  <TerrifyingHallucinations.baseInspectLine>حالة عقلية: هلوسات مرعبة</TerrifyingHallucinations.baseInspectLine>
  <!-- EN: Vivid  hallucinations swirl around {0}, twisting and distorting allies into horrifying abominations. {PAWN_pronoun} will flee from anyone {PAWN_pronoun} perceives as a threat. -->
  <TerrifyingHallucinations.beginLetter>هلوسات حية تدور حول {0}، تلتوي وتشوه الحلفاء إلى رجاسات مرعبة. سيهرب {PAWN_pronoun} من أي شخص يعتبره {PAWN_pronoun} تهديدًا.</TerrifyingHallucinations.beginLetter>
  <!-- EN: terrifying hallucinations -->
  <TerrifyingHallucinations.beginLetterLabel>هلوسات مرعبة</TerrifyingHallucinations.beginLetterLabel>
  <!-- EN: {0} is no longer hallucinating. -->
  <TerrifyingHallucinations.recoveryMessage>لم يعد {0} يهلوس.</TerrifyingHallucinations.recoveryMessage>
  
</LanguageData>